{
   "manifest_version": 3,
   "default_locale": "en",
   "name": "__MSG_extensionName__",
   "version": "3.0.0",
   "description": "__MSG_extensionDescription__",
   "author": "kk1",
   "icons": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
   },
   "action": {
      "default_icon": {
         "16": "icons/icon16.png",
         "24": "icons/icon24.png",
         "32": "icons/icon32.png"
      },
      "default_title": "__MSG_actionTitle__",
      "default_popup": "popup.html"
   },
   "background": {
      "service_worker": "background.js",
      "type": "module"
   },
   "commands": {
      "open_current_changes_view": {
         "description": "Open 'Current quantity/structure changes' view"
      },
      "open_backup_history_view": {
         "suggested_key": {
            "default": "Alt+2",
            "mac": "Alt+2",
            "windows": "Alt+2",
            "linux": "Alt+2"
         },
         "description": "Open 'Backup history' view"
      }
   },
   "permissions": [
      "bookmarks",
      "storage",
      "unlimitedStorage",
      "alarms",
      "commands",
      "scripting",
      "windows",
    "tabs",
    "tabGroups",
      "downloads",
      "downloads.shelf",
      "pageCapture",
      "activeTab",
      "favicon"
   ],
   "host_permissions": [
      "<all_urls>"
   ]
}
